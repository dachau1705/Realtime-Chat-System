{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2022",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@libs/common": ["libs/common/src/index.ts"],
      "@libs/redis": ["libs/redis/src/index.ts"],
      "@libs/kafka": ["libs/kafka/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "apps/frontend"]
}
