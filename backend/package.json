{
  "name": "realtime-chat-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "start:api": "nodemon --watch apps/api-gateway -e ts --exec ts-node -r tsconfig-paths/register apps/api-gateway/src/main.ts",
    "start:ws": "nodemon --watch apps/websocket-gateway -e ts --exec ts-node -r tsconfig-paths/register apps/websocket-gateway/src/main.ts",
    "start:worker": "nodemon --watch apps/worker -e ts --exec ts-node -r tsconfig-paths/register apps/worker/src/main.ts",
    "test:load": "ts-node -r tsconfig-paths/register tests/load-test.ts",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:migrate": "ts-node -r tsconfig-paths/register migrations/migrate.ts"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "axios": "^1.17.0",
    "cloudinary": "^2.10.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "multer": "^2.1.1",
    "pg": "^8.11.3",
    "sharp": "^0.35.1",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/form-data": "^2.2.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.8.10",
    "@types/pg": "^8.10.7",
    "@types/uuid": "^9.0.6",
    "form-data": "^4.0.5",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  }
}
